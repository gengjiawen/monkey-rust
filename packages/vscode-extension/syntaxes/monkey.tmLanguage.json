{
  "scopeName": "source.monkey",
  "name": "Monkey",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    {
      "match": "[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.other.monkey"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.monkey",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.monkey",
          "begin": "\"",
          "end": "\"",
          "patterns": []
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.monkey",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.monkey",
          "match": "\\b(fn|let|if|else|return|true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.monkey",
          "match": "==|!=|[-+*/<>]=?|=|,|;|:|\\(|\\)|\\[|\\]|\\{|\\}"
        }
      ]
    }
  }
}
